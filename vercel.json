{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/socket.io/(.*)", "dest": "/server.js" },
    { "src": "/admin/(.*)", "dest": "/server.js" },
    { "src": "/published/(.*)", "dest": "/server.js" },
    { "src": "/health", "dest": "/server.js" },
    { "src": "/(.*\\.(html|css|js|png|ico|json))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}